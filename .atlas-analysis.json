  "keyFeatures": [
    "42 built-in datasets spanning QA, reasoning, code, summarization, NLI, instruction following, long context, and agent traces",
    "8 auto-wired evaluators including answer quality (F1/EM), math equivalence, code execution, and LLM-as-judge",
    "7 aggregation metrics including compression ratio, cost-of-pass, latency, and Pareto ranking",
    "Side-by-side multi-system comparison with Pareto frontier analysis",
    "Resumable runs via JSONL result caching",
    "Concurrent evaluation with configurable thread pool",
    "Memory system benchmarking (naive, embedding, RLM, Mem0, Zep) on LoCoMo and LongMemEval",
    "DSPy optimizer sweep benchmarking across multiple datasets and budget tiers",
    "Protocol-based extension: implement .process(), .score(), or .compute() — no subclassing required",
    "Multiple output formats: table, JSON, HTML"
  ],
  "publicApiSurface": [
    "evaluate(systems, dataset, evaluators, metrics, max_workers, cache_dir)",
    "evaluate_memory(systems, dataset, evaluators, metrics, max_examples, progress)",
    "OpenAIProxy(base_url, model, name, api_key, system_prompt, extra_body)",
    "ClaudeCLI",
    "EvalResult.summary / .to_json() / .to_dataframe() / .filter()",
    "EvalRow",
    "MemorySystem protocol (reset, ingest, query)",
    "System protocol (.name, .process)",
    "Evaluator protocol (.name, .score)",
    "Metric protocol (.name, .compute)",
    "AnswerQuality()",
    "SummarizationQuality()",
    "MultipleChoiceAccuracy()",
    "CodeExecution(timeout)",
    "MathEquivalence()",
    "NLILabelMatch()",
    "IFEvalChecker()",
    "LLMJudge(base_url, model)",
    "MeanScore(score_field)",
    "PassRate(threshold, score_field)",
    "CompressionRatio()",
    "CostOfPass(threshold, score_field)",
    "Latency()",
    "PerDatasetBreakdown(score_field)",
    "ParetoRank",
